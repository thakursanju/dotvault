{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "commonjs",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "types": ["hardhat/types", "chai", "node", "mocha"]
  },
  "include": [
    "./hardhat.config.ts",
    "./contracts/**/*.ts",
    "./test/**/*.ts",
    "./scripts/**/*.ts"
  ]
}